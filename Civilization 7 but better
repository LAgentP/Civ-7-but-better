import tkinter as tk
from collections import defaultdict

unit_type_list=["Warrior", "Archer", "Scout"]
unit_type_color={
    "Warrior" : "blue", 
    "Archer" : "Green",
    "Scout" : "Purple"
    }

#                  unit type   HP / DMG / DEF
unit_type_stat = {"Warrior" : [3, 2, 1], 
                  "Archer" : [3, 2, 0], 
                  "Scout" : [1, 1, 1]}

row_number = 5
col_number = 5

