def menu_warrior_spawn_option(popup_event):
    Unit.spawn_unit(popup_event, "Warrior")

def menu_archer_spawn_option(popup_event):
    Unit.spawn_unit(popup_event, "Archer")

def menu_change_name_option(popup_event):
    if Cell.check_unit(event=popup_event)==False:
        print("No unit to rename here")
        return


    def close_popup_window(entry, window):
        global entry_text
        entry_text=entry.get()
        window.destroy()
        if len(entry_text)==0:
            print("No new name")

        else:
            print(f"New name is '{entry_text}'")

            for i in range(len(Unit.UNI_instance_list)):
                if (Unit.UNI_instance_list[i].x, Unit.UNI_instance_list[i].y) == check_click_position(popup_event):
                    print("Got a match")
                    Unit.UNI_instance_list[i].change_name(entry_text)
                    return

    toplevel_popup = tk.Toplevel(bg="#9C9C9C")
    toplevel_popup.resizable(False, False)
    toplevel_popup.geometry('+0+0')
    toplevel_popup.title("Popup")

    new_name_entry = tk.Entry(toplevel_popup, bg="#C4C4C4", highlightbackground="black", highlightthickness=2, highlightcolor="black", font="TkDefaultFont 20")
    new_name_entry.pack(expand=True, fill="both", padx=5, pady=5)

    close_button=tk.Button(toplevel_popup, text="Confirm", command = lambda:close_popup_window(entry=new_name_entry, window=toplevel_popup))
    close_button.pack(fill="both")





for i in range (row_number):
    fen.grid_rowconfigure(i, weight=1,uniform=1)
for i in range(col_number):
    fen.grid_columnconfigure(i, weight=2,uniform=1)
    
Cell.create_grid()
Menu(fen)

fen.bind("<Button-3>",Menu.show_click_menu)

