                    unit_to_remove = Unit.instance_list[i]
                    unit_to_remove.label.destroy()

                    Cell.instance_list[x][y].update_unit_on_cell(unit_to_remove, add=False)
                    Unit.instance_list.remove(unit_to_remove)
                    print("Unit removed")
                
        else:
            print("No unit to delete")

