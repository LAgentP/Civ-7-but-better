class Main():
    def __init__(self, row_number=5, col_number=5):
        self.row_number=row_number
        self.col_number=col_number

        Main.configure_main_window(self)
        Main.configure_grid(self)
        Main.assign_bind(self)

        Cell.create_grid(window=self.main_window)
        Menu(self.main_window)
        
    def get_grid_size(self):
        print(f"row {self.row_number}, col {self.col_number}")
        return self.row_number, self.col_number
        pass

    def configure_main_window(self):
        self.main_window=tk.Tk()
        self.main_window.title("Grille")
        self.main_window.geometry("700x500+-5+0")
        self.main_window.configure(bg="#7C7C7C",padx=5,pady=5)
        pass

    def configure_grid(self):
        for i in range (row_number):
            self.main_window.grid_rowconfigure(i, weight=1,uniform=1)
        for i in range(col_number):
            self.main_window.grid_columnconfigure(i, weight=2,uniform=1)

    def assign_bind(self):
#        self.main_window.bind("<Button-2>",a)
        self.main_window.bind("<Button-3>",Menu.show_click_menu)
    
    pass

class Cell:
    instance_list=[[None for a in range(col_number)] for b in range(row_number)]

    terrain=None
    country=None
    city=False

    def __init__(self, window, x_coo, y_coo, color):
        
        self.x_coo=x_coo
        self.y_coo=y_coo
        self.color=color
        
        self.frame=tk.Frame(window, bg=self.color)
        self.frame.grid(row=x_coo, column=y_coo, padx=5, pady=5, sticky="nswe")
        
        self.unit_on_cell=[]

        pass

    def __str__(self):
        return f"This is the cell {self.x_coo},{self.y_coo}. There is the unit {self.unit_on_cell} here."
    
    def create_grid(window):
        for i in range(row_number):
            for j in range(col_number):
                cell=Cell(window=window, x_coo=i, y_coo=j, color="red")
                Cell.instance_list[j][i]=cell

        pass
    
    def change_terrain(self, terrain):
        self.terrain=terrain
        pass

    def change_country(self, country):
        self.country=country
        pass

    def change_city(self, city):
        self.city=city
        pass
    
    def change_color(self,color):
        self.frame.configure(bg=color)

    def update_unit_on_cell(self, unit, add):
        if add==True:
            self.unit_on_cell.append(unit)
        if add==False:
            self.unit_on_cell.remove(unit)
        print(self.unit_on_cell)
        

    def check_unit(x=None, y=None, event=None):
        if event!=None:
            x, y = Cell.check_click_position(event)
        if len(Cell.instance_list[x][y].frame.winfo_children())==0:
            return False
        else:
            print('A unit is on this tile')
            return True
        
    def check_click_position(event):
        for x in range(col_number):
            for y in range(row_number):
                main_window = main.__dict__["main_window"]


                current_cell=Cell.instance_list[x][y].frame

                current_cell_x=current_cell.winfo_x()
                current_cell_y=current_cell.winfo_y()

                current_cell_width=current_cell.winfo_width()
                current_cell_height=current_cell.winfo_height()

                main_window_x=main_window.winfo_x()
                main_window_y=main_window.winfo_y()

                mouse_x=event.x_root - main_window_x - 8
                mouse_y=event.y_root - main_window_y - 32

            

                if current_cell_x <= mouse_x <= current_cell_x+current_cell_width and current_cell_y <= mouse_y <= current_cell_y+current_cell_height:
                    return x,y
            
        print("No cell clicked")
        return False

    def get_cell_stat(event):
        if Cell.check_click_position(event)==False:
            return
        
        else:
            if Cell.check_unit(event=event)==True:
                for i in range(len(Unit.instance_list)):
                    uni_x_pos=Unit.instance_list[i].x
                    uni_y_pos=Unit.instance_list[i].y
                    if (uni_x_pos, uni_y_pos) == Cell.check_click_position(event):
                        print(Unit.instance_list[i])
                        return
            else:
                print("No unit to show stat")
            return

class Menu:
    instance_list=[]

    def __init__(self, window):
        self.main_menu=tk.Menu(window, tearoff=0)
        self.instance_list.append(self.main_menu)

        Menu.create_popup_menu(self)
        
    def create_popup_menu(self):
        Menu.add_submenus(self, self.main_menu)
        Menu.add_opt(self)

    def add_submenus(self, submenu):
        self.submenu=submenu
        self.submenu = tk.Menu(self.main_menu, tearoff=0)
        self.instance_list.append(self.submenu)

        self.main_menu.add_cascade(label="Spawn a unit", menu = self.submenu)
        self.main_menu.add_separator()
    
    def add_opt(self):
        
        for i in unit_type_list:
            self.submenu.add_command(label=i, command = lambda i=i : Unit.spawn_unit(popup_event, i))
            
        self.main_menu.add_command(label="Change unit name", command = lambda : Menu.menu_change_name_option(popup_event))
        self.main_menu.add_command(label="Despawn unit", command = lambda : Unit.despawn_unit(popup_event))
        self.main_menu.add_command(label="Se unit stats", command = lambda : Cell.get_cell_stat(popup_event))

    def show_click_menu(event):
        if Cell.check_click_position(event)==False:
            return

        global popup_event
        popup_event = event
        Menu.instance_list[0].tk_popup(event.x_root, event.y_root)
        pass

    def menu_change_name_option(popup_event):
        if Cell.check_unit(event=popup_event)==False:
            print("No unit to rename here")
            return



        toplevel_popup = tk.Toplevel(bg="#9C9C9C")
        toplevel_popup.resizable(False, False)
        toplevel_popup.geometry('+0+0')
        toplevel_popup.title("Popup")

        new_name_entry = tk.Entry(toplevel_popup, bg="#C4C4C4", highlightbackground="black", highlightthickness=2, highlightcolor="black", font="TkDefaultFont 20")
        new_name_entry.pack(expand=True, fill="both", padx=5, pady=5)

        close_button=tk.Button(toplevel_popup, text="Confirm", command = lambda:Menu.close_popup_window(entry=new_name_entry, window=toplevel_popup))
        close_button.pack(fill="both")

    def close_popup_window(entry, window):
        global entry_text
        entry_text=entry.get()
        window.destroy()
        if len(entry_text)==0:
            print("No new name")

        else:
            print(f"New name is '{entry_text}'")

            for i in range(len(Unit.instance_list)):
                if (Unit.instance_list[i].x, Unit.instance_list[i].y) == Cell.check_click_position(popup_event):
                    print("Got a match")
                    Unit.instance_list[i].change_name(entry_text)
                    return


    pass

class Unit:

    instance_list=[]

    def __init__(self, x, y, unit_type, name):
        self.Unit_HP = unit_type_stat[unit_type][0]
        self.Unit_DMG = unit_type_stat[unit_type][1]
        self.Unit_DEF = unit_type_stat[unit_type][2]

        self.x=x
        self.y=y
        self.unit_type = unit_type
        self.name = name
        window=Cell.instance_list[x][y].frame
        
        self.label = tk.Label(window, bg=unit_type_color[unit_type], text=str(unit_type))
        self.label.pack(fill="both", expand=True, padx=10, pady=10)

        globals()[unit_type].instance_list.append(self)
        Unit.instance_list.append(self)
        Cell.instance_list[x][y].update_unit_on_cell(self, add=True)
        
        pass

    def __str__(self):
        return f"########\nThis is a {self.unit_type}.\nHe's located in the cell {self.x,self.y}\nHis name is {self.name}.\nHP : {self.Unit_HP} / DMG : {self.Unit_DMG} / DEF : {self.Unit_DEF}\n########"
        pass

    def change_name(self, name):
        self.name=name
    
    def spawn_unit(event, unit_type):
        if Cell.check_click_position(event)==False:
            return
        else:
            x,y = Cell.check_click_position(event)
            print(f"Clicked cell ({x},{y})")

        if Cell.check_unit(x, y)==True:
            return

        try:
            globals()[unit_type](x, y)                      # Executes Warrior(x,y) if unit_type=="Warrior", etc...
        except KeyError:
            print("This kind of unit does not exist")
            pass

    def despawn_unit(event):
        if Cell.check_click_position(event)==False:
            return
        x,y = Cell.check_click_position(event)

        if Cell.check_unit(x, y)==True:
            Cell.instance_list[x][y].frame.winfo_children()[0].destroy()        # Destroys the label

            for i in range(len(Unit.instance_list)):
                if (Unit.instance_list[i].x, Unit.instance_list[i].y) == Cell.check_click_position(event):
                    unit_to_remove = Unit.instance_list[i]
                    
                    Cell.instance_list[x][y].update_unit_on_cell(unit_to_remove, add=False)
                    Unit.instance_list.remove(unit_to_remove)
                    print("Unit removed")
                    return
                
        else:
            print("No unit to delete")

