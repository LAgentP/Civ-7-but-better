def check_click_position(event):
    for x in range(col_number):
        for y in range(row_number):

            current_cell=Cell.CEL_instance_list[x][y].frame

            current_cell_x=current_cell.winfo_x()
            current_cell_y=current_cell.winfo_y()

            current_cell_width=current_cell.winfo_width()
            current_cell_height=current_cell.winfo_height()

            fen_x=fen.winfo_x()
            fen_y=fen.winfo_y()

            mouse_x=event.x_root - fen_x - 8
            mouse_y=event.y_root - fen_y - 32

            

            if current_cell_x <= mouse_x <= current_cell_x+current_cell_width and current_cell_y <= mouse_y <= current_cell_y+current_cell_height:
                return x,y
            
    print("No cell clicked")
    return False


