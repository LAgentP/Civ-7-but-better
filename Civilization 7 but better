import tkinter as tk

fen=tk.Tk()
fen.title("Grille")
fen.geometry("700x500+-5+0")
fen.configure(bg="#7C7C7C",padx=5,pady=5)
row_number = 5
col_number = 5
class Cell:
    CEL_instance_list=[[None for a in range(col_number)] for b in range(row_number)]

    terrain=None
    country=None
    city=False

    def __init__(self, window, x_coo, y_coo, color):
        self.x_coo=x_coo
        self.y_coo=y_coo
        self.color=color
        
        self.frame=tk.Frame(window, bg=self.color)
        self.frame.grid(row=x_coo, column=y_coo, padx=5, pady=5, sticky="nswe")
        pass

    def __str__(self):
        return f"This is the cell {self.x_coo},{self.y_coo}"
    
    def create_grid():
        for i in range(row_number):
            for j in range(col_number):
                cell=Cell(window=fen, x_coo=i, y_coo=j, color="red")
                Cell.CEL_instance_list[j][i]=cell

        pass
    
    def check_unit(x=None, y=None, event=None):
        if event!=None:
            x, y = check_click_position(event)
        if len(Cell.CEL_instance_list[x][y].frame.winfo_children())==0:
            return False
        else:
            print('A unit is on this tile')
            return True

    def coordinates(self):
        print(f"x = {self.x_coo} y = {self.y_coo}")
        pass

    def change_terrain(self, terrain):
        self.terrain=terrain
        pass

    def change_country(self, country):
        self.country=country
        pass

    def change_city(self, city):
        self.city=city
        pass
    
    def change_color(self,color):
        self.frame.configure(bg=color)

    def get_cell_stat(event):
        if check_click_position(event)==False:
            return
        
        else:
            if Cell.check_unit(event=event)==True:
                for i in range(len(Unit.UNI_instance_list)):
                    uni_x_pos=Unit.UNI_instance_list[i].x
                    uni_y_pos=Unit.UNI_instance_list[i].y
                    if (uni_x_pos, uni_y_pos) == check_click_position(event):
                        print(Unit.UNI_instance_list[i])
                        return
            else:
                print("No unit to show stat")
            return



    pass


class Menu:
    MEN_instance_list=[]

    def __init__(self, window):
        self.main_menu=tk.Menu(window, tearoff=0)
        self.MEN_instance_list.append(self.main_menu)

        Menu.create_popup_menu(self)
        
    def create_popup_menu(self):
        Menu.add_submenus(self, self.main_menu)
        Menu.add_opt(self)

    def add_submenus(self, submenu):
        print("submenu =", submenu)
        self.submenu=submenu
        self.submenu = tk.Menu(self.main_menu, tearoff=0)
        self.MEN_instance_list.append(self.submenu)

        self.main_menu.add_cascade(label="Spawn a unit", menu = self.submenu)
        self.main_menu.add_separator()
    
    def add_opt(self):

        self.submenu.add_command(label="Warrior", command = lambda : menu_warrior_spawn_option(popup_event))
        self.submenu.add_command(label="Archer", command = lambda : menu_archer_spawn_option(popup_event))
        self.main_menu.add_command(label="Despawn unit", command = lambda : Unit.despawn_unit(popup_event))
        self.main_menu.add_command(label="Se unit stats", command = lambda : Cell.get_cell_stat(popup_event))
        self.main_menu.add_command(label="Change unit name", command = lambda : menu_change_name_option(popup_event))

    def show_click_menu(event):
        if check_click_position(event)==False:
            return

        global popup_event
        popup_event = event
        Menu.MEN_instance_list[0].tk_popup(event.x_root, event.y_root)
        pass


    pass

class Unit:

    UNI_instance_list=[]

    def __init__(self, x, y, unit_type, name):
        self.x=x
        self.y=y
        self.unit_type = unit_type
        self.name = name
        window=Cell.CEL_instance_list[x][y].frame
        
        self.label = tk.Label(window, bg="blue", text=str(unit_type))
        self.label.pack(fill="both", expand=True, padx=10, pady=10)
        Unit.UNI_instance_list.append(self)
        
        pass

    def __str__(self):
        return f"########\nThis is a {self.unit_type}.\nHe's located in the cell {self.x,self.y}\nHis name is {self.name}.\nHP : {self.Unit_HP} / DMG : {self.Unit_DMG} / DEF : {self.Unit_DEF}\n########"
        pass

    def change_name(self, name):
        self.name=name
    
    def spawn_unit(event, unit_type):
        if check_click_position(event)==False:
            return
        
        else:
            x,y = check_click_position(event)
            print(f"Clicked cell ({x},{y})")

            if Cell.check_unit(x, y)==True:
                return
            else:
                if unit_type=="Warrior":
                    Warrior(x, y)
                elif unit_type=="Archer":
                    Archer(x,y)

    def despawn_unit(event):
        if check_click_position(event)==False:
            return
        
        else:
            x,y = check_click_position(event)
            print(f"Clicked ({x},{y})")

            if Cell.check_unit(x, y)==True:
                Cell.CEL_instance_list[x][y].frame.winfo_children()[0].destroy()        # Destroys the label
                for i in range(len(Unit.UNI_instance_list)):
                    if (Unit.UNI_instance_list[i].x, Unit.UNI_instance_list[i].y) == check_click_position(event):
                        unit_to_remove = Unit.UNI_instance_list[i]
                        Unit.UNI_instance_list.remove(unit_to_remove)
                        print("Unit removed")
                        return
            else:
                print("No unit to delete")
        pass

